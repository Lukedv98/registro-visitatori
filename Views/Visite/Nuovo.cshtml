@model RegistroVisitatori.Models.Visita

<h1>Nuovo visitatore</h1>

<form asp-action="Nuovo" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Nome</label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Cognome</label>
        <input asp-for="Cognome" class="form-control" />
        <span asp-validation-for="Cognome" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Azienda</label>
        <input asp-for="Azienda" class="form-control" />
        <span asp-validation-for="Azienda" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Persona da incontrare</label>
        <input asp-for="Referente" class="form-control" />
        <span asp-validation-for="Referente" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Motivo della visita</label>
        <input asp-for="MotivoVisita" class="form-control" />
        <span asp-validation-for="MotivoVisita" class="text-danger"></span>
    </div>

    <button class="btn btn-primary" type="submit">Registra ingresso</button>
    <a class="btn btn-secondary" asp-action="Presenti">Annulla</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
