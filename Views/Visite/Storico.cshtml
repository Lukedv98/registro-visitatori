@model List<RegistroVisitatori.Models.Visita>

@{
    ViewData["Title"] = "Storico visite";
}


<h1 class="mb-4">Storico visite</h1>

<form method="get" class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div class="fw-semibold">Filtra per periodo</div>
            <div class="text-muted small">Storico visite</div>
        </div>

        <div class="row g-3 align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label text-muted small mb-1">Da</label>
                <input type="date" name="da" class="form-control" value="@(Context.Request.Query["da"])" />
            </div>

            <div class="col-12 col-md-4">
                <label class="form-label text-muted small mb-1">A</label>
                <input type="date" name="a" class="form-control" value="@(Context.Request.Query["a"])" />
            </div>

            <div class="col-12 col-md-4 d-flex gap-2">
                <button class="btn btn-primary w-100" type="submit">
                    <i class="bi bi-funnel"></i> Applica
                </button>

                <a class="btn btn-outline-secondary w-100" asp-action="Storico">
                    <i class="bi bi-arrow-counterclockwise"></i> Reset
                </a>
            </div>
        </div>
    </div>
</form>
@{
    var daQ = Context.Request.Query["da"].ToString();
    var aQ = Context.Request.Query["a"].ToString();
    bool hasFilters = !string.IsNullOrWhiteSpace(daQ) || !string.IsNullOrWhiteSpace(aQ);
}

@if (hasFilters)
{
    <div class="d-flex flex-wrap align-items-center gap-2 mb-4">
    <span class="text-muted small">Filtri attivi:</span>

    @if (!string.IsNullOrWhiteSpace(daQ))
        {
            <span class="badge rounded-pill bg-light text-dark border">
                Da: <b>@daQ</b>
            </span>
        }

        @if (!string.IsNullOrWhiteSpace(aQ))
        {
            <span class="badge rounded-pill bg-light text-dark border">
                A: <b>@aQ</b>
            </span>
        }

        <a class="btn btn-sm btn-outline-secondary ms-auto" asp-action="Storico">
            <i class="bi bi-x-circle"></i> Rimuovi filtri
        </a>
    </div>
}
else
{
    <div class="text-muted small mb-4">
    Nessun filtro attivo.
</div>
}

@if (!Model.Any())
{
    <p>Nessuna visita nello storico.</p>
}
else
{
    <p class="text-muted">
    Archivio delle visite concluse.
</p>
    <table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Azienda</th>
            <th></th>
            <th>Stato</th>
            <th>Ora ingresso</th>
            <th>Ora uscita</th>
            <th></th>

        </tr>
    </thead>
    <tbody>
        @foreach (var v in Model)
            {
                <tr>
                    <td>@v.Nome @v.Cognome</td>
                    <td>@v.Azienda</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal"
                            data-bs-target="#dettagliModal-@v.Id">
                            Dettagli
                        </button>
                    </td>
                    <td>
                        <span class="badge bg-secondary">Conclusa</span>
                    </td>
                    <td>@v.OraIngresso.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@(v.OraUscita?.ToString("dd/MM/yyyy HH:mm"))</td>
                    <td>
                        <button type="button" class="btn btn-sm btn-outline-secondary btn-delete" data-bs-toggle="modal"
                            data-bs-target="#deleteModal" data-id="@v.Id" data-returnto="Storico" title="Elimina">
                            <i class="bi bi-trash text-secondary"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @foreach (var v in Model)
    {
        <div class="modal fade" id="dettagliModal-@v.Id" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-sm">
            <div class="modal-header">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <i class="bi bi-card-text"></i>
                    Dettagli visita
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Chiudi"></button>
            </div>

            <div class="modal-body">
                <div class="d-flex align-items-start gap-3 mb-3">
                    <div class="icon-circle">
                        <i class="bi bi-person-badge"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="text-muted small">Persona da incontrare</div>
                        <div class="fw-semibold">
                            @(string.IsNullOrWhiteSpace(v.Referente) ? "-" : v.Referente)
                        </div>
                    </div>
                </div>

                <hr class="my-3" />

                <div class="d-flex align-items-start gap-3">
                    <div class="icon-circle">
                        <i class="bi bi-chat-left-text"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="text-muted small">Motivo visita</div>
                        <div>
                            @(string.IsNullOrWhiteSpace(v.MotivoVisita) ? "-" : v.MotivoVisita)
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Chiudi
                </button>
            </div>
        </div>

    </div>
</div>
    }
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Aurea Services - Conferma eliminazione</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Chiudi"></button>
            </div>
            <div class="modal-body">
                @if (TempData["DeleteError"] != null)
                    {
                        <div class="alert alert-danger mb-3">
                            @TempData["DeleteError"]
                        </div>
                    }
                    <div class="mb-2">
                        <label class="form-label">Password di conferma</label>
                        <input type="password" class="form-control" id="deletePassword" required />
                        <div class="form-text">Inserisci la password per confermare l’eliminazione.</div>
                    </div>
                    <p>
                        Stai per eliminare definitivamente questa visita dal registro aziendale.<br />
                        L’operazione non è reversibile.
                    </p>
                    <p class="mb-0">Vuoi procedere?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annulla</button>

                    <form id="deleteForm" asp-action="Elimina" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" id="deleteId" />
                        <input type="hidden" name="returnTo" id="deleteReturnTo" value="Storico" />
                        <input type="hidden" name="password" id="deletePasswordHidden" />
                        <button type="submit" class="btn btn-danger">Elimina</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

}
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            const deleteModalEl = document.getElementById('deleteModal');
            if (!deleteModalEl) return;

            const modal = new bootstrap.Modal(deleteModalEl);

            deleteModalEl.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                if (!button) return;

                const id = button.getAttribute('data-id');
                const returnTo = button.getAttribute('data-returnto');

                document.getElementById('deleteId').value = id;
                document.getElementById('deleteReturnTo').value = returnTo;

                document.getElementById('deletePassword').value = '';
                document.getElementById('deletePasswordHidden').value = '';
            });

            const deleteForm = document.getElementById('deleteForm');
            if (deleteForm) {
                deleteForm.addEventListener('submit', function () {
                    document.getElementById('deletePasswordHidden').value =
                        document.getElementById('deletePassword').value;
                });
            }

        @if (TempData["OpenDeleteModal"]?.ToString() == "1")
        {
            <text>
                        document.getElementById('deleteId').value = '@TempData["DeleteId"]';
                        document.getElementById('deleteReturnTo').value = '@TempData["DeleteReturnTo"]';
                        modal.show();
            </text>
        }

                });
    </script>
}